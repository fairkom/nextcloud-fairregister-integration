{
	"name": "fairregister",
	"description": "Register Nextcloud files as Works in fairregister.",
	"version": "0.2.0",
	"author": "fairkom <philipp.monz@fairkom.eu>",
	"contributors": [],
	"bugs": {
		"url": "https://git.fairkom.net/hosting/faircommons/-/issues"
	},
	"license": "agpl",
	"private": true,
	"scripts": {
		"build": "webpack --node-env production --progress",
		"dev": "webpack --node-env development --progress",
		"watch": "webpack --node-env development --progress --watch",
		"lint": "eslint --ext .js,.vue src",
		"lint:fix": "eslint --ext .js,.vue src --fix",
		"stylelint": "stylelint src/**/*.scss src/**/*.vue",
		"stylelint:fix": "stylelint src/**/*.scss src/**/*.vue --fix"
	},
	"dependencies": {
		"@nextcloud/axios": "^2.5.0",
		"@nextcloud/dialogs": "^7.0.0",
		"@nextcloud/files": "^3.10.2",
		"@nextcloud/initial-state": "^2.2.0",
		"@nextcloud/l10n": "^3.1.0",
		"@nextcloud/router": "^3.0.1",
		"@nextcloud/vue": "^8.16.0",
		"vue": "^3.4.0",
		"vue-material-design-icons": "^5.3.1"
	},
	"browserslist": [
		"extends @nextcloud/browserslist-config"
	],
	"engines": {
		"node": "^20.0.0",
		"npm": "^10.0.0"
	},
	"devDependencies": {
		"@nextcloud/babel-config": "^1.2.0",
		"@nextcloud/browserslist-config": "^3.0.0",
		"@nextcloud/eslint-config": "^8.4.1",
		"@nextcloud/stylelint-config": "^3.0.1",
		"@nextcloud/webpack-vue-config": "^6.0.1"
	}
}
